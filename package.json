{
  "name": "local-llm-rn",
  "version": "1.0.1",
  "packageManager": "pnpm@10.29.2",
  "description": "On-device LLM inference for React Native with Metal (iOS) and Vulkan (Android) GPU acceleration",
  "main": "src/index.ts",
  "react-native": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "src/",
    "ios/",
    "android/",
    "cpp/",
    "local-llm-rn.podspec",
    "!cpp/.gitkeep"
  ],
  "scripts": {
    "smoke:native-bridge": "vitest run tests/native-contract.test.ts tests/native-bridge.test.ts tests/local-llm.test.ts tests/vision.test.ts && bash scripts/verify-vendoring.sh",
    "verify:vendoring": "bash scripts/verify-vendoring.sh",
    "prepare": "bash scripts/prepare.sh",
    "prepack": "bash scripts/prepack.sh",
    "release": "node scripts/release.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.76"
  },
  "dependencies": {
    "local-llm-js-core": "0.2.1"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "react-native": "^0.76.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  },
  "codegenConfig": {
    "name": "LocalLLMSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.hilum.localllm"
    }
  },
  "keywords": [
    "react-native",
    "llm",
    "local-llm",
    "on-device",
    "inference",
    "llama",
    "metal",
    "vulkan",
    "ai",
    "machine-learning"
  ],
  "author": "Hilum Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hilum-labs/local-llm-rn"
  },
  "homepage": "https://github.com/hilum-labs/local-llm-rn#readme",
  "bugs": {
    "url": "https://github.com/hilum-labs/local-llm-rn/issues"
  }
}
