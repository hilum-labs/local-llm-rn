{
  "name": "local-llm-rn",
  "version": "1.0.3",
  "packageManager": "pnpm@10.29.2",
  "description": "On-device LLM inference for React Native with Metal (iOS) and Vulkan (Android) GPU acceleration",
  "main": "src/index.ts",
  "react-native": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "src/",
    "ios/",
    "android/",
    "cpp/",
    "local-llm-rn.podspec",
    "!cpp/.gitkeep"
  ],
  "scripts": {
    "smoke:native-bridge": "vitest run tests/native-contract.test.ts tests/native-bridge.test.ts tests/local-llm.test.ts tests/vision.test.ts && bash scripts/verify-vendoring.sh",
    "verify:core-version": "node scripts/verify-core-version.mjs",
    "verify:release": "node scripts/validate-release.mjs",
    "verify:vendoring": "bash scripts/verify-vendoring.sh",
    "prepare": "bash scripts/prepare.sh",
    "prepack": "bash scripts/prepack.sh",
    "release": "node scripts/release.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.76"
  },
  "dependencies": {
    "local-llm-js-core": "0.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "react-native": "^0.76.0",
    "typescript": "^5.5.0",
    "vite": "7.3.5",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "@babel/plugin-transform-modules-systemjs@>=7.12.0 <7.29.4": "7.29.7",
      "@babel/core@<7.29.6": "7.29.7",
      "brace-expansion@<2": "1.1.16",
      "esbuild@<0.28.1": "0.28.1",
      "js-yaml@<4": "3.15.0",
      "node-forge@<=1.3.3": "1.4.0",
      "picomatch@<3": "2.3.2",
      "picomatch@>=4 <4.0.5": "4.0.5",
      "shell-quote@<=1.8.3": "1.10.0",
      "postcss@<8.5.10": "8.5.19",
      "vite@>=7 <7.3.5": "7.3.5",
      "ws@>=6 <7": "6.2.5",
      "ws@>=7 <8": "7.5.12"
    }
  },
  "codegenConfig": {
    "name": "LocalLLMSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.hilum.localllm"
    }
  },
  "keywords": [
    "react-native",
    "llm",
    "local-llm",
    "on-device",
    "inference",
    "llama",
    "metal",
    "vulkan",
    "ai",
    "machine-learning"
  ],
  "author": "Hilum Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hilum-labs/local-llm-rn"
  },
  "homepage": "https://github.com/hilum-labs/local-llm-rn#readme",
  "bugs": {
    "url": "https://github.com/hilum-labs/local-llm-rn/issues"
  }
}
